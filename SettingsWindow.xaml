<Window x:Class="SeniorUtilities.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource SettingsTitle}"
        Height="360" Width="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="GreenBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2C5F2D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#245020"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1B3D18"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#2C5F2D" Padding="16,10">
            <TextBlock Text="{DynamicResource SettingsTitle}"
                       FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                       Foreground="White"/>
        </Border>

        <!-- Тело -->
        <StackPanel Grid.Row="1" Margin="20,16,20,0">

            <!-- Язык -->
            <TextBlock Text="{DynamicResource SettingsLangLabel}"
                       Style="{StaticResource FieldLabel}"
                       FontWeight="SemiBold" Margin="0,0,0,8"/>
            <RadioButton x:Name="rbRu" Content="Русский"
                         GroupName="Lang"
                         FontFamily="Segoe UI" FontSize="13"
                         Margin="4,0,0,8" Cursor="Hand"/>
            <RadioButton x:Name="rbEn" Content="English"
                         GroupName="Lang"
                         FontFamily="Segoe UI" FontSize="13"
                         Margin="4,0,0,0" Cursor="Hand"/>

            <Separator Margin="0,16,0,12"/>

            <!-- Поведение -->
            <TextBlock Text="{DynamicResource BehaviorGroupLabel}"
                       Style="{StaticResource FieldLabel}"
                       FontWeight="SemiBold" Margin="0,0,0,8"/>
            <CheckBox x:Name="cbAutoStart"
                      Content="{DynamicResource OptAutoStart}"
                      FontFamily="Segoe UI" FontSize="13"
                      Margin="4,0,0,8" Cursor="Hand"/>
            <CheckBox x:Name="cbTray"
                      Content="{DynamicResource OptTray}"
                      FontFamily="Segoe UI" FontSize="13"
                      Margin="4,0,0,0" Cursor="Hand"/>
        </StackPanel>

        <!-- Подвал -->
        <Border Grid.Row="2" Background="#E8E8E8"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource SettingsCancel}"
                        Click="Cancel_Click"
                        Width="80" Height="28" Margin="0,0,8,0"
                        FontFamily="Segoe UI" FontSize="11"
                        Cursor="Hand"/>
                <Button Content="{DynamicResource SettingsApply}"
                        Style="{StaticResource GreenBtn}"
                        Click="Apply_Click"
                        Width="80" Height="28" Padding="0"
                        FontFamily="Segoe UI" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
