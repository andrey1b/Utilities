<Window x:Class="SeniorUtilities.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppTitle}"
        Icon="app.ico"
        Height="480" Width="720"
        MinHeight="420" MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Background="#D0E8D0"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>

        <!-- Стиль плитки-кнопки (как в Senior Hub) -->
        <Style x:Key="TileStyle" TargetType="Button">
            <Setter Property="Width"  Value="200"/>
            <Setter Property="Height" Value="168"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="12">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="10"
                                                 ShadowDepth="3" Opacity="0.18"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка «Настройки» под цвет подвала -->
        <Style x:Key="SettingsBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#A8C8A8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#98B898"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#88A888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#2C5F2D" Padding="28,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🛠️" FontSize="34" VerticalAlignment="Center"
                           Margin="0,0,14,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource AppTitle}"
                               FontFamily="Segoe UI" FontSize="26" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{DynamicResource AppSubtitle}"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#A8D5A9" Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Плитки -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="20,28,20,20" Orientation="Horizontal">

                <!-- Исправление раскладки -->
                <Button x:Name="TileLayoutBtn" Style="{StaticResource TileStyle}"
                        Click="ToggleLayoutFix"
                        ToolTip="{DynamicResource TileLayoutTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⌨️" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TileLayout}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TileLayoutSub}"
                                   FontSize="11" Foreground="#E8F0E8"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="168"/>
                        <Border x:Name="LayoutStateBadge"
                                CornerRadius="9" Padding="10,2" Margin="0,8,0,0"
                                HorizontalAlignment="Center" Background="#FFFFFF">
                            <TextBlock x:Name="LayoutStateText"
                                       FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Button>

                <!-- Снимок → текст (OCR) -->
                <Button Style="{StaticResource TileStyle}" Background="#00838F"
                        Click="RunOcr"
                        ToolTip="{DynamicResource TileOcrTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📷" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TileOcr}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TileOcrSub}"
                                   FontSize="11" Foreground="#B2DFDB"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="168"/>
                    </StackPanel>
                </Button>

                <!-- Включить гибернацию -->
                <Button Style="{StaticResource TileStyle}" Background="#5E35B1"
                        Click="OpenHibernation"
                        ToolTip="{DynamicResource TileHibTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="💤" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TileHib}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TileHibSub}"
                                   FontSize="11" Foreground="#D1C4E9"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="168"/>
                    </StackPanel>
                </Button>

            </WrapPanel>
        </ScrollViewer>

        <!-- Подвал -->
        <Border Grid.Row="2" Background="#B8D4B8"
                BorderBrush="#9CBD9C" BorderThickness="0,1,0,0"
                Padding="20,7">
            <Grid>
                <TextBlock x:Name="tbVersion"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="#3A5A3A" HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{DynamicResource FooterInfo}"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="#3A5A3A" HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <Button Style="{StaticResource SettingsBtnStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="OpenSettings"
                        ToolTip="{DynamicResource SettingsTip}">
                    <TextBlock Text="⚙" FontSize="15" Foreground="#2C5F2D"/>
                </Button>
            </Grid>
        </Border>

    </Grid>
</Window>
