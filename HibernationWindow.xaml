<Window x:Class="SeniorUtilities.HibernationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource HibTitle}"
        Icon="app.ico"
        Height="420" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#D0E8D0"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="14,10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#5E35B1" Padding="20,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="💤" FontSize="30" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="{DynamicResource HibTitle}" Foreground="White"
                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Содержимое -->
        <StackPanel Grid.Row="1" Margin="20,16,20,8">
            <TextBlock Text="{DynamicResource HibIntro}" TextWrapping="Wrap"
                       Foreground="#33503F" FontSize="13" Margin="0,0,0,16"/>

            <Button x:Name="BtnFix" Style="{StaticResource ActionBtn}" Background="#5E35B1"
                    Click="OnFixClick" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{DynamicResource HibFixBtn}" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource HibFixHint}" FontSize="11"
                               Foreground="#EDE7F6" TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnNow" Style="{StaticResource ActionBtn}" Background="#2C5F2D"
                    Click="OnHibernateNowClick">
                <StackPanel>
                    <TextBlock Text="{DynamicResource HibNowBtn}" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource HibNowHint}" FontSize="11"
                               Foreground="#DCEFE4" TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>
            </Button>

            <TextBlock x:Name="TxtStatus" Foreground="#5E35B1" FontSize="12"
                       Margin="2,14,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Подвал -->
        <Border Grid.Row="2" Background="#B8D4B8" BorderBrush="#9CBD9C"
                BorderThickness="0,1,0,0" Padding="16,8">
            <Button Content="{DynamicResource HibClose}" Click="OnCloseClick"
                    HorizontalAlignment="Right" Padding="16,5" Cursor="Hand"
                    Background="#A8C8A8" BorderThickness="0" Foreground="#2C5F2D"/>
        </Border>
    </Grid>
</Window>
