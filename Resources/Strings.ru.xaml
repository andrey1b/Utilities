<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Шапка -->
    <sys:String x:Key="AppTitle">Утилиты</sys:String>
    <sys:String x:Key="AppSubtitle">Маленькие помощники для повседневной работы</sys:String>

    <!-- Плитка: исправление раскладки -->
    <sys:String x:Key="TileLayout">Раскладка</sys:String>
    <sys:String x:Key="TileLayoutSub">Исправить набранный не в той раскладке текст</sys:String>
    <sys:String x:Key="TileLayoutTip">Выделите текст и нажмите Pause/Break — раскладка исправится (Цштвщцы → Windows)</sys:String>
    <sys:String x:Key="StateOn">Включено</sys:String>
    <sys:String x:Key="StateOff">Выключено</sys:String>
    <sys:String x:Key="LayoutHotkey">Горячая клавиша: Pause / Break</sys:String>

    <!-- Плитка: снимок → текст (OCR) -->
    <sys:String x:Key="TileOcr">Снимок</sys:String>
    <sys:String x:Key="TileOcrSub">Распознать текст на экране в буфер обмена</sys:String>
    <sys:String x:Key="TileOcrTip">Выделите область экрана с текстом — он будет распознан и скопирован в буфер обмена</sys:String>
    <sys:String x:Key="OcrHint">Выделите область с текстом мышью · Esc — отмена</sys:String>
    <sys:String x:Key="OcrDone">Текст распознан и скопирован ({0} симв.)</sys:String>
    <sys:String x:Key="OcrEmpty">Текст не распознан. Попробуйте выделить область крупнее или чётче.</sys:String>
    <sys:String x:Key="OcrUnavailable">Распознавание текста недоступно: в Windows не установлен языковой компонент OCR.</sys:String>
    <sys:String x:Key="OcrLangLabel">Язык распознавания текста</sys:String>
    <sys:String x:Key="OcrLangAuto">Авто</sys:String>

    <!-- Плитка: гибернация -->
    <sys:String x:Key="TileHib">Гибернация</sys:String>
    <sys:String x:Key="TileHibSub">Включить и настроить · уйти в гибернацию</sys:String>
    <sys:String x:Key="TileHibTip">Включить гибернацию, отключить «будилки», при желании сразу уйти в гибернацию</sys:String>

    <!-- Окно гибернации -->
    <sys:String x:Key="HibTitle">Гибернация</sys:String>
    <sys:String x:Key="HibIntro">Гибернация сохраняет открытые программы на диск и полностью выключает ПК — при включении всё восстановится. Настройка также отключает «будилки», чтобы компьютер не просыпался сам.</sys:String>
    <sys:String x:Key="HibFixBtn">Включить и настроить</sys:String>
    <sys:String x:Key="HibFixHint">Включит гибернацию и запретит устройствам и таймерам будить ПК. Откроется окно с правами администратора (UAC) и отчётом.</sys:String>
    <sys:String x:Key="HibNowBtn">Гибернировать сейчас</sys:String>
    <sys:String x:Key="HibNowHint">Немедленно увести компьютер в гибернацию.</sys:String>
    <sys:String x:Key="HibClose">Закрыть</sys:String>
    <sys:String x:Key="HibNowConfirm">Увести компьютер в гибернацию сейчас?</sys:String>
    <sys:String x:Key="HibCancelled">Действие отменено.</sys:String>
    <sys:String x:Key="HibFixStarted">Открыто окно настройки (с правами администратора).</sys:String>

    <!-- Подвал -->
    <sys:String x:Key="VersionLabel">Версия</sys:String>
    <sys:String x:Key="FooterInfo">Выделите текст и нажмите Pause/Break</sys:String>

    <!-- Трей -->
    <sys:String x:Key="TrayShow">Открыть окно</sys:String>
    <sys:String x:Key="TrayExit">Выход</sys:String>
    <sys:String x:Key="TrayTip">Утилиты — работают в фоне</sys:String>
    <sys:String x:Key="TrayMinimized">Программа свёрнута в область уведомлений. Горячая клавиша продолжает работать.</sys:String>

    <!-- Настройки -->
    <sys:String x:Key="SettingsTip">Настройки</sys:String>
    <sys:String x:Key="SettingsTitle">Настройки</sys:String>
    <sys:String x:Key="SettingsLangLabel">Язык интерфейса</sys:String>
    <sys:String x:Key="SettingsApply">Применить</sys:String>
    <sys:String x:Key="SettingsCancel">Отмена</sys:String>
    <sys:String x:Key="BehaviorGroupLabel">Поведение</sys:String>
    <sys:String x:Key="OptAutoStart">Запускать при входе в Windows</sys:String>
    <sys:String x:Key="OptTray">Сворачивать в трей при закрытии окна</sys:String>

</ResourceDictionary>
