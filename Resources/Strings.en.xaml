<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Header -->
    <sys:String x:Key="AppTitle">Utilities</sys:String>
    <sys:String x:Key="AppSubtitle">Small helpers for everyday work</sys:String>

    <!-- Tile: keyboard layout fix -->
    <sys:String x:Key="TileLayout">Layout</sys:String>
    <sys:String x:Key="TileLayoutSub">Fix text typed in the wrong keyboard layout</sys:String>
    <sys:String x:Key="TileLayoutTip">Select text and press Pause/Break — the layout is fixed (Цштвщцы → Windows)</sys:String>
    <sys:String x:Key="StateOn">On</sys:String>
    <sys:String x:Key="StateOff">Off</sys:String>
    <sys:String x:Key="LayoutHotkey">Hotkey: Pause / Break</sys:String>

    <!-- Tile: screenshot → text (OCR) -->
    <sys:String x:Key="TileOcr">Screenshot</sys:String>
    <sys:String x:Key="TileOcrSub">Recognize on-screen text to the clipboard</sys:String>
    <sys:String x:Key="TileOcrTip">Select a screen area with text — it will be recognized and copied to the clipboard</sys:String>
    <sys:String x:Key="OcrHint">Drag to select an area with text · Esc to cancel</sys:String>
    <sys:String x:Key="OcrDone">Text recognized and copied ({0} chars)</sys:String>
    <sys:String x:Key="OcrEmpty">No text recognized. Try a larger or clearer area.</sys:String>
    <sys:String x:Key="OcrUnavailable">Text recognition is unavailable: the Windows OCR language component is not installed.</sys:String>
    <sys:String x:Key="OcrLangLabel">Text recognition language</sys:String>
    <sys:String x:Key="OcrLangAuto">Auto</sys:String>

    <!-- Tile: hibernation -->
    <sys:String x:Key="TileHib">Hibernate</sys:String>
    <sys:String x:Key="TileHibSub">Enable &amp; configure · hibernate now</sys:String>
    <sys:String x:Key="TileHibTip">Enable hibernation, disable wake sources, and optionally hibernate right away</sys:String>

    <!-- Hibernation window -->
    <sys:String x:Key="HibTitle">Hibernation</sys:String>
    <sys:String x:Key="HibIntro">Hibernation saves open programs to disk and fully powers off the PC — everything is restored when you turn it on. The setup also disables wake sources so the PC won't wake on its own.</sys:String>
    <sys:String x:Key="HibFixBtn">Enable &amp; configure</sys:String>
    <sys:String x:Key="HibFixHint">Enables hibernation and prevents devices and timers from waking the PC. A window with administrator rights (UAC) and a report will open.</sys:String>
    <sys:String x:Key="HibNowBtn">Hibernate now</sys:String>
    <sys:String x:Key="HibNowHint">Put the computer into hibernation immediately.</sys:String>
    <sys:String x:Key="HibClose">Close</sys:String>
    <sys:String x:Key="HibNowConfirm">Put the computer into hibernation now?</sys:String>
    <sys:String x:Key="HibCancelled">Action cancelled.</sys:String>
    <sys:String x:Key="HibFixStarted">Setup window opened (with administrator rights).</sys:String>

    <!-- Footer -->
    <sys:String x:Key="VersionLabel">Version</sys:String>
    <sys:String x:Key="FooterInfo">Select text and press Pause/Break</sys:String>

    <!-- Tray -->
    <sys:String x:Key="TrayShow">Open window</sys:String>
    <sys:String x:Key="TrayExit">Exit</sys:String>
    <sys:String x:Key="TrayTip">Utilities — running in background</sys:String>
    <sys:String x:Key="TrayMinimized">The app is minimized to the notification area. The hotkey keeps working.</sys:String>

    <!-- Settings -->
    <sys:String x:Key="SettingsTip">Settings</sys:String>
    <sys:String x:Key="SettingsTitle">Settings</sys:String>
    <sys:String x:Key="SettingsLangLabel">Interface language</sys:String>
    <sys:String x:Key="SettingsApply">Apply</sys:String>
    <sys:String x:Key="SettingsCancel">Cancel</sys:String>
    <sys:String x:Key="BehaviorGroupLabel">Behavior</sys:String>
    <sys:String x:Key="OptAutoStart">Start with Windows</sys:String>
    <sys:String x:Key="OptTray">Minimize to tray when window is closed</sys:String>

</ResourceDictionary>
